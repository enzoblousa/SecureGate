# Copie este arquivo para docker-compose.override.yml (já está no .gitignore) para
# testar o envio de e-mail com um provedor real em vez do smtp4dev local.
#
# Exemplo com Gmail:
# 1. Ative a verificação em duas etapas na sua conta Google.
# 2. Gere uma senha de app em https://myaccount.google.com/apppasswords.
# 3. Preencha os valores abaixo e rode `docker compose up -d --build` normalmente —
#    o Docker Compose mescla este arquivo com o docker-compose.yml automaticamente.

services:
  api:
    environment:
      Smtp__Host: "smtp.gmail.com"
      Smtp__Port: "587"
      Smtp__From: "seu-email@gmail.com"
      Smtp__Username: "seu-email@gmail.com"
      Smtp__Password: "sua-senha-de-app-de-16-caracteres"
      Smtp__EnableStartTls: "true"
